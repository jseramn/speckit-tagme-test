# InsForge (https://insforge.dev) — server & scripts
INSFORGE_URL=https://your-project.us-east.insforge.app
INSFORGE_ANON_KEY=your-anon-key
INSFORGE_SERVICE_KEY=your-service-role-key

# InsForge — browser client (Next.js requires NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_INSFORGE_URL=https://your-project.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-key

# App — set to Vercel production/preview URL when deployed
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AVEX — OpenRouter via InsForge Model Gateway (server-only)
# Run: npx @insforge/cli ai setup
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini

# Staff dev auth (optional — local testing without InsForge user)
# Set STAFF_DEV_TOKEN and pass Authorization: Bearer <token> on admin API calls.
STAFF_DEV_TOKEN=
STAFF_DEV_VENUE_SLUG=hotel-caribe
STAFF_DEV_ROLE=admin
STAFF_DEV_NAME=Staff Dev

# Executive dev auth (optional — bypass InsForge login for /executive routes in development)
# Set STAFF_DEV_EXECUTIVE_ROLE to executive | manager | department_head.
# Combine with STAFF_DEV_TOKEN; optional STAFF_DEV_EXECUTIVE_SCOPE for manager/department_head.
STAFF_DEV_EXECUTIVE_ROLE=
STAFF_DEV_EXECUTIVE_SCOPE=

# Executive alerts cron (M3+) — protect POST /api/executive/alerts/evaluate
# Vercel Cron sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Executive demo users seed (scripts/seed-hotel-caribe.ts) — do NOT commit real passwords
EXECUTIVE_DEMO_PASSWORD=

# E2E executive smoke (tests/e2e/executive-overview.spec.ts) — optional with npm run dev
# STAFF_DEV_TOKEN=dev-local-token
# STAFF_DEV_EXECUTIVE_ROLE=executive